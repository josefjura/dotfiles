# ~/.zshrc — Catppuccin Mocha system setup

# XDG
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CACHE_HOME="$HOME/.cache"

# PATH
export PATH="$HOME/.local/bin:$PATH"

# Wayland / Hyprland
export MOZ_ENABLE_WAYLAND=1
export QT_QPA_PLATFORM=wayland
export GDK_BACKEND=wayland,x11

# Editor
export EDITOR=nvim
export VISUAL=nvim

# Pager
export PAGER=bat
export MANPAGER="sh -c 'col -bx | bat -l man -p'"

# fzf — Catppuccin Mocha colors
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_DEFAULT_OPTS=" \
  --color=bg+:#313244,bg:#1e1e2e,spinner:#f5e0dc,hl:#f38ba8 \
  --color=fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc \
  --color=marker:#b4befe,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8 \
  --color=selected-bg:#45475a \
  --multi"
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"

# bat theme
export BAT_THEME="Catppuccin Mocha"

# SSH agent auto-start
if ! pgrep -u "$USER" ssh-agent > /dev/null; then
    ssh-agent -t 1h > "$XDG_RUNTIME_DIR/ssh-agent.env"
fi
if [[ ! -S "$SSH_AUTH_SOCK" ]]; then
    source "$XDG_RUNTIME_DIR/ssh-agent.env" > /dev/null
fi

# Aliases
alias ls='eza --icons'
alias ll='eza -l --icons --git'
alias la='eza -la --icons --git'
alias lt='eza --tree --icons -L 2'
alias cat='bat'
alias grep='rg'
alias cd='z'
alias g='lazygit'
alias v='nvim'
alias vim='nvim'
alias zj='zellij'

# Git aliases
alias gs='git status'
alias gd='git diff'
alias gl='git log --oneline --graph'

# Zsh options
setopt AUTO_CD
setopt CORRECT
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt SHARE_HISTORY
setopt EXTENDED_HISTORY

HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000

# Completion
autoload -Uz compinit
compinit
zstyle ':completion:*' menu select
zstyle ':completion:*' matcher-list 'm:{a-z}={A-Za-z}'

# Plugins
ZSH_PLUGIN_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/zsh/plugins"

load_plugin() {
  local plugin=$1 file=$2
  local dir="$ZSH_PLUGIN_DIR/$plugin"
  [[ -f "$dir/$file" ]] && source "$dir/$file"
}

load_plugin zsh-autosuggestions     zsh-autosuggestions.zsh
load_plugin zsh-syntax-highlighting zsh-syntax-highlighting.zsh
load_plugin fzf-tab                 fzf-tab.plugin.zsh

ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE='fg=#585b70'
ZSH_AUTOSUGGEST_STRATEGY=(history completion)

# fzf — Arch puts it here
[[ -f /usr/share/fzf/key-bindings.zsh ]] && source /usr/share/fzf/key-bindings.zsh
[[ -f /usr/share/fzf/completion.zsh ]]   && source /usr/share/fzf/completion.zsh

# Zoxide
eval "$(zoxide init zsh)"

# mise
command -v mise &>/dev/null && eval "$(mise activate zsh)"

# Starship
eval "$(starship init zsh)"

# Yazi — cd on exit
function yy() {
  local tmp; tmp="$(mktemp -t "yazi-cwd.XXXXXX")"
  yazi "$@" --cwd-file="$tmp"
  if cwd="$(cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
    builtin cd -- "$cwd"
  fi
  rm -f -- "$tmp"
}
